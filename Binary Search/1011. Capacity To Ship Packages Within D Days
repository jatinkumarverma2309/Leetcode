class Solution {
    public int shipWithinDays(int[] weights, int days) {
        int lo=0, hi=0;
        for(int w: weights){
            lo=Math.max(lo,w); 
            hi+=w;
        }
        int ans=0;
        while(lo<=hi){
            int mid=lo+(hi-lo)/2;
            if(sum(weights,days,mid)){
                ans=mid;
                hi=mid-1;
            }
            else{
                lo=mid+1;
            }
        }
        return ans;
    }
    public boolean sum(int[] weights, int days, int cap){
        int d=1, curr=0;
        for(int w:weights){
            curr+=w;
            if(curr>cap){
                d++;
                curr=w;
            }
        }
        return d<=days;
    }
}