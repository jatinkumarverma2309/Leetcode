class Solution {
    public int smallestDivisor(int[] nums, int threshold) {
        int low = 1;
        int high = maxElement(nums);
        int ans = high;

        while (low <= high) {
            int mid = low + (high - low) / 2;

            long sum = calculateSum(nums, mid);

            if (sum <= threshold) {
                ans = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }

        return ans;
    }

    private int maxElement(int[] nums) {
        int max = nums[0];

        for (int num : nums) {
            max = Math.max(max, num);
        }

        return max;
    }

    private long calculateSum(int[] nums, int divisor) {
        long sum = 0;

        for (int num : nums) {
            sum += (num + (long) divisor - 1) / divisor;
        }

        return sum;
    }
}