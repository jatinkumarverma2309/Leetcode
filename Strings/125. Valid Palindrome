class Solution {
    public boolean isPalindrome(String s) {
        s=s.toLowerCase();
        int m=0;
        int n=s.length()-1;
        while(m<=n){
            if(!(Character.isLetter(s.charAt(m))||Character.isDigit(s.charAt(m)))){
                m++; continue;
            }
            if(!(Character.isLetter(s.charAt(n))||Character.isDigit(s.charAt(n)))){
                n--; continue;
            }
            if(s.charAt(m)!=s.charAt(n)){
                return false;
            }
            m++;
            n--;
        }
        return true;
    }
}